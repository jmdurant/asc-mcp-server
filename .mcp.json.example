{
  "mcpServers": {
    "app-store-connect": {
      "command": "node",
      "args": ["dist/index.js"],
      "env": {
        "ASC_KEY_ID": "${ASC_KEY_ID}",
        "ASC_ISSUER_ID": "${ASC_ISSUER_ID}",
        "ASC_KEY_PATH": "${ASC_KEY_PATH}",
        "ASC_CONTACT_PHONE": "${ASC_CONTACT_PHONE}"
      }
    }
  }
}
